{% macro getImportantDatesError(fieldErrors, ERROR_CODES, monthField, yearField) %}
  {%- if fieldErrors and (fieldErrors[monthField] or fieldErrors[yearField]) -%}
    {# Check if this is the earliest date field #}
    {%- set isEarliestDate = (monthField == 'earliestWithGiaMonth') -%}

    {%- if fieldErrors[monthField] == ERROR_CODES.MONTH_REQUIRED or fieldErrors[yearField] == ERROR_CODES.YEAR_REQUIRED -%}
      {%- if isEarliestDate -%}
        earliest_date_required
      {%- else -%}
        required
      {%- endif -%}
    {%- elif fieldErrors[monthField] == ERROR_CODES.MONTH_INVALID or fieldErrors[yearField] == ERROR_CODES.YEAR_INVALID -%}
      {%- if isEarliestDate -%}
        earliest_date_invalid
      {%- else -%}
        invalid
      {%- endif -%}
    {%- elif fieldErrors[monthField] == ERROR_CODES.DATE_OUTSIDE_FINANCIAL_RANGE or fieldErrors[yearField] == ERROR_CODES.DATE_OUTSIDE_FINANCIAL_RANGE -%}
      outside_financial_range
    {%- elif fieldErrors[monthField] == ERROR_CODES.DATE_BEFORE_PREVIOUS_STAGE or fieldErrors[yearField] == ERROR_CODES.DATE_BEFORE_PREVIOUS_STAGE -%}
      before_previous_stage
    {%- elif fieldErrors[monthField] == ERROR_CODES.DATE_BEFORE_FINANCIAL_START or fieldErrors[yearField] == ERROR_CODES.DATE_BEFORE_FINANCIAL_START -%}
      earliest_date_before_financial_start
    {%- elif fieldErrors[monthField] == ERROR_CODES.DATE_AFTER_OBC_START or fieldErrors[yearField] == ERROR_CODES.DATE_AFTER_OBC_START -%}
      earliest_date_after_obc_start
    {%- endif -%}
  {%- endif -%}
{% endmacro %}