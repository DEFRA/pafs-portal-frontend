{% extends 'layouts/page.njk' %}
{% from "button.njk" import govukButton %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% set status = downloadStatus.status if downloadStatus else 
  'empty' %}
{% set projectCounts = downloadStatus.projectCounts if downloadStatus else 
  null %}

{# Progress percentage for admin progress bar #}
{% set progressPct = 0 %}
{% if downloadStatus and downloadStatus.progressTotal > 0 %}
  {% set progressPct = ((downloadStatus.progressCurrent / downloadStatus.progressTotal) * 100) | round %}
{% endif %}

{% block content %}

  {% if flash %}
    {{ govukNotificationBanner({
      type: flash.type,
      html: '<p class="govuk-body">' + flash.text + '</p>'
    }) }}
  {% endif %}

  <h1 class="govuk-heading-xl">
    {{ heading }}
  </h1>

  {# ── Proposal counts panel ──────────────────────────────────────────────── #}
  {% if projectCounts %}
    <div class="govuk-grid-row govuk-!-margin-bottom-6">
      <div class="govuk-grid-column-one-half">
        <h2 class="govuk-heading-m">
          {{ t('download.admin.counts.heading') if isAdmin else t('download.programme.counts.heading') }}
        </h2>
        <ul class="govuk-list govuk-list--spaced">
          <li>{{ t('download.programme.counts.submitted') }}: <strong>{{ projectCounts.submitted }}</strong>
          </li>
          <li>{{ t('download.programme.counts.draft') }}: <strong>{{ projectCounts.draft }}</strong>
          </li>
          <li>{{ t('download.programme.counts.revise') }}: <strong>{{ projectCounts.revise }}</strong>
          </li>
          <li>{{ t('download.programme.counts.approved') }}: <strong>{{ projectCounts.approved }}</strong>
          </li>
          <li>{{ t('download.programme.counts.rejected') }}: <strong>{{ projectCounts.rejected }}</strong>
          </li>
          <li>{{ t('download.programme.counts.archived') }}: <strong>{{ projectCounts.archived }}</strong>
          </li>
        </ul>
        <p class="govuk-body">{{ t('download.programme.counts.total') }}: <strong>{{ projectCounts.total }}</strong>
        </p>
        {% if isAdmin %}
          <p class="govuk-body govuk-hint">{{ t('download.admin.counts.note') }}</p>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {# ── Status panel ───────────────────────────────────────────────────────── #}
  {#
    data-module, data-download-status, data-poll-url and data-is-admin feed the
    progressive-enhancement JS in application.js.
    Without JS: a <noscript> meta refresh auto-reloads while generating.
  #}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds"
         data-module="programme-download"
         data-download-status="{{ status }}"
         data-poll-url="{{ routes.poll }}"
         data-is-admin="{{ 'true' if isAdmin else 'false' }}">

      {# EMPTY / FAILED ──────────────────────────────────────────────────── #}
      {% if status === 'empty' or status === 'failed' %}

        {% if status === 'failed' %}
          {{ govukNotificationBanner({
            type: 'important',
            titleText: t('download.programme.failed.title'),
            html: '<p class="govuk-body">' + t('download.programme.failed.body') + '</p>'
          }) }}
        {% endif %}

        <p class="govuk-body">
          {{ t('download.admin.empty.description') if isAdmin else t('download.programme.empty.description') }}
        </p>

        {% if not isAdmin %}
          <details class="govuk-details">
            <summary class="govuk-details__summary">
              <span class="govuk-details__summary-text">
                {{ t('download.programme.empty.why_summary') }}
              </span>
            </summary>
            <div class="govuk-details__text">
              {{ t('download.programme.empty.why_detail') }}
            </div>
          </details>
        {% endif %}

        <form method="post" action="{{ routes.generate }}">
          <input type="hidden" name="crumb" value="{{ crumb }}">
          {{ govukButton({
            text: t('download.admin.button.generate') if isAdmin else t('download.programme.button.generate'),
            classes: "govuk-!-margin-top-2",
            preventDoubleClick: true
          }) }}
        </form>

        {# GENERATING ──────────────────────────────────────────────────────── #}
      {% elif status === 'generating' %}

        <div class="govuk-inset-text" id="js-generating-panel">
          <h2 class="govuk-heading-s">
            {{ t('download.admin.generating.heading') if isAdmin else t('download.programme.generating.heading') }}
          </h2>
          <p class="govuk-body" id="js-progress-message">
            {{ downloadStatus.progressMessage or (t('download.admin.generating.default_message') if isAdmin else t('download.programme.generating.default_message')) }}
          </p>

          {# Admin shows an accessible progress bar; users see simple count text #}
          {% if isAdmin and downloadStatus.progressTotal > 0 %}
            <div class="govuk-!-margin-bottom-2">
              <div role="progressbar"
                   aria-label="{{ t('download.admin.generating.progress_label') }}"
                   aria-valuenow="{{ progressPct }}"
                   aria-valuemin="0"
                   aria-valuemax="100"
                   style="background:#f3f2f1; border-radius:4px; height:20px; overflow:hidden;">
                <div id="js-progress-bar"
                     style="background:#00703c; height:100%; width:{{ progressPct }}%; transition:width 0.5s ease;"></div>
              </div>
            </div>
            <p class="govuk-body govuk-hint" id="js-progress-count">
              {{ downloadStatus.progressCurrent }}
              {{ t('download.programme.generating.of') }}
              {{ downloadStatus.progressTotal }}
              ({{ progressPct }}%)
            </p>
          {% elif not isAdmin and downloadStatus.progressTotal > 0 %}
            <p class="govuk-body govuk-hint" id="js-progress-count">
              {{ downloadStatus.progressCurrent }}
              {{ t('download.programme.generating.of') }}
              {{ downloadStatus.progressTotal }}
            </p>
          {% endif %}

          <p class="govuk-body">
            {{ t('download.admin.generating.email_notice') if isAdmin else t('download.programme.generating.email_notice') }}
          </p>
        </div>

        {% if downloadStatus.requestedOn %}
          <p class="govuk-body govuk-hint">
            {{ t('download.programme.generating.requested_on') }}
            {{ downloadStatus.requestedOn | formatDate('d MMMM yyyy') }}
          </p>
        {% endif %}

        <form method="post" action="{{ routes.generate }}">
          <input type="hidden" name="crumb" value="{{ crumb }}">
          {{ govukButton({
            text: t('download.admin.button.generate_again') if isAdmin else t('download.programme.button.generate_again'),
            classes: "govuk-!-margin-top-2",
            preventDoubleClick: true
          }) }}
        </form>

        {# No-JS fallback: auto-refresh every 10 seconds while generating #}
        <noscript><meta http-equiv="refresh" content="10"></noscript>

        {# READY ───────────────────────────────────────────────────────────── #}
      {% elif status === 'ready' %}

        <h2 class="govuk-heading-m">
          {{ t('download.admin.ready.heading') if isAdmin else t('download.programme.ready.heading') }}
        </h2>

        {% if downloadStatus.requestedOn %}
          <p class="govuk-body govuk-hint govuk-!-margin-bottom-1">
            {{ t('download.programme.ready.generated_on') }}
            {{ downloadStatus.requestedOn | formatDate('d MMMM yyyy') }}
          </p>
        {% endif %}
        {% if downloadStatus.numberOfProposals is not null %}
          <p class="govuk-body govuk-hint govuk-!-margin-bottom-6">
            {{ t('download.programme.ready.included_proposals') }}
            <strong>{{ downloadStatus.numberOfProposals }}</strong>
            {{ t('download.admin.ready.proposals') if isAdmin else t('download.programme.ready.proposals') }}
          </p>
        {% endif %}

        {# FCERM1 — available for both admin and user #}
        {% if downloadStatus.hasFcerm1 %}
          <section class="gem-c-attachment govuk-!-margin-bottom-6">
            <div class="gem-c-attachment__thumbnail">
              <a href="{{ routes.fcerm1 }}" class="govuk-link" tabindex="-1" aria-hidden="true">
                <svg class="gem-c-attachment__thumbnail-image gem-c-attachment__thumbnail-image--spreadsheet"
                     version="1.1" viewBox="0 0 99 140" width="99" height="140" aria-hidden="true">
                  <path d="M12 12h75v27H12zm0 47h18.75v63H12zm55 2v59H51V61h16m2-2H49v63h20V59z" stroke-width="0"/>
                  <path d="M49 61.05V120H32.8V61.05H49m2-2H30.75v63H51V59zm34 2V120H69.05V61.05H85m2-2H67v63h20V59z" stroke-width="0"/>
                  <path d="M30 68.5h56.5M30 77.34h56.5M30 112.7h56.5M30 95.02h56.5M30 86.18h56.5M30 103.86h56.5" fill="none" stroke-miterlimit="10" stroke-width="2"/>
                </svg>
              </a>
            </div>
            <div class="gem-c-attachment__details">
              <h3 class="gem-c-attachment__title">
                <a href="{{ routes.fcerm1 }}" class="govuk-link gem-c-attachment__link">
                  {{ t('download.admin.ready.fcerm1_label') if isAdmin else t('download.programme.ready.fcerm1_label') }}
                </a>
              </h3>
              <p class="gem-c-attachment__metadata">
                <span class="gem-c-attachment__attribute">MS Excel Spreadsheet (.xlsx)</span>
              </p>
              {% if downloadStatus.numberOfProposals is not null %}
                <p class="gem-c-attachment__metadata">
                  <span class="gem-c-attachment__attribute">There are {{ downloadStatus.numberOfProposals }} proposal{{ 's' if downloadStatus.numberOfProposals !== 1 }} in this programme</span>
                </p>
              {% endif %}
              {% if isAdmin %}
                <p class="gem-c-attachment__metadata">
                  <span class="gem-c-attachment__attribute">{{ t('download.admin.ready.fcerm1_hint') }}</span>
                </p>
              {% endif %}
            </div>
          </section>
        {% endif %}

        {# Benefit areas ZIP — user downloads only #}
        {% if not isAdmin and downloadStatus.hasBenefitAreas %}
          <section class="gem-c-attachment govuk-!-margin-bottom-6">
            <div class="gem-c-attachment__thumbnail">
              <a href="{{ routes.benefitAreas }}" class="govuk-link gem-c-attachment__thumbnail-image" tabindex="-1" aria-hidden="true">
                <img src="/public/assets/images/pub-cover-zip.png" width="99" height="140" alt="" aria-hidden="true">
              </a>
            </div>
            <div class="gem-c-attachment__details">
              <h3 class="gem-c-attachment__title">
                <a href="{{ routes.benefitAreas }}" class="govuk-link gem-c-attachment__link">
                  {{ t('download.programme.ready.benefit_areas_label') }}
                </a>
              </h3>
              <p class="gem-c-attachment__metadata">
                <span class="gem-c-attachment__attribute">ZIP file</span>
              </p>
              {% if downloadStatus.numberOfBenefitAreas is not null %}
                <p class="gem-c-attachment__metadata">
                  <span class="gem-c-attachment__attribute">There are {{ downloadStatus.numberOfBenefitAreas }} benefit area{{ 's' if downloadStatus.numberOfBenefitAreas !== 1 }} in this compressed folder</span>
                </p>
              {% endif %}
            </div>
          </section>
        {% endif %}

        {# Moderation forms ZIP — user downloads only #}
        {% if not isAdmin and downloadStatus.hasModerations %}
          <section class="gem-c-attachment govuk-!-margin-bottom-6">
            <div class="gem-c-attachment__thumbnail">
              <a href="{{ routes.moderations }}" class="govuk-link" tabindex="-1" aria-hidden="true">
                <svg class="gem-c-attachment__thumbnail-image gem-c-attachment__thumbnail-image--document"
                     version="1.1" viewBox="0 0 99 140" width="99" height="140" aria-hidden="true">
                  <path d="M12 12h75v27H12zM12 59h9v9h-9zM12 77h9v9h-9zM12 95h9v9h-9zM12 113h9v9h-9zM30 59h57v9H30zM30 77h39v9H30zM30 95h57v9H30zM30 113h48v9H30z" stroke-width="0"/>
                </svg>
              </a>
            </div>
            <div class="gem-c-attachment__details">
              <h3 class="gem-c-attachment__title">
                <a href="{{ routes.moderations }}" class="govuk-link gem-c-attachment__link">
                  {{ t('download.programme.ready.moderations_label') }}
                </a>
              </h3>
              <p class="gem-c-attachment__metadata">
                <span class="gem-c-attachment__attribute">ZIP file</span>
              </p>
            </div>
          </section>
        {% endif %}

        <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">

        <form method="post" action="{{ routes.generate }}">
          <input type="hidden" name="crumb" value="{{ crumb }}">
          {{ govukButton({
            text: t('download.admin.button.regenerate') if isAdmin else t('download.programme.button.regenerate'),
            classes: "govuk-!-margin-top-4",
            preventDoubleClick: true
          }) }}
        </form>

      {% endif %}

    </div>
  </div>

{% endblock %}