{% macro fundingSourcesAndSpendingSummaryCard(projectData, PROJECT_PAYLOAD_FIELDS, PROJECT_STEPS, t, isReadOnly, formatNumberWithCommas) %}

  {% set p = 'projects.overview.funding_sources_summary_card' %}
  {% set slug = projectData[PROJECT_PAYLOAD_FIELDS.SLUG] %}

  {# Determine whether any funding source has been selected #}
  {% set hasFundingSources = projectData[PROJECT_PAYLOAD_FIELDS.FCERM_GIA]
    or projectData[PROJECT_PAYLOAD_FIELDS.LOCAL_LEVY]
    or projectData['additionalFcermGia']
    or projectData[PROJECT_PAYLOAD_FIELDS.PUBLIC_CONTRIBUTIONS]
    or projectData[PROJECT_PAYLOAD_FIELDS.PRIVATE_CONTRIBUTIONS]
    or projectData[PROJECT_PAYLOAD_FIELDS.OTHER_EA_CONTRIBUTIONS]
    or projectData[PROJECT_PAYLOAD_FIELDS.NOT_YET_IDENTIFIED] %}

  {% set fundingValues = projectData.processedFundingValues or projectData[PROJECT_PAYLOAD_FIELDS.FUNDING_VALUES] or [] %}
  {% set hasSpend = fundingValues | length > 0 %}

  {# Build ordered list of active sources for the DETAIL (expanded) table #}
  {% set activeSources = [] %}

  {% if projectData[PROJECT_PAYLOAD_FIELDS.FCERM_GIA] %}
    {% set activeSources = activeSources.concat([{ field: PROJECT_PAYLOAD_FIELDS.FCERM_GIA, label: t(p + '.gia') }]) %}
  {% endif %}
  {% if projectData[PROJECT_PAYLOAD_FIELDS.LOCAL_LEVY] %}
    {% set activeSources = activeSources.concat([{ field: PROJECT_PAYLOAD_FIELDS.LOCAL_LEVY, label: t(p + '.local_levy') }]) %}
  {% endif %}
  {% if projectData[PROJECT_PAYLOAD_FIELDS.ASSET_REPLACEMENT_ALLOWANCE] %}
    {% set activeSources = activeSources.concat([{ field: PROJECT_PAYLOAD_FIELDS.ASSET_REPLACEMENT_ALLOWANCE, label: t(p + '.asset_replacement_allowance'), additionalGia: true }]) %}
  {% endif %}
  {% if projectData[PROJECT_PAYLOAD_FIELDS.ENVIRONMENT_STATUTORY_FUNDING] %}
    {% set activeSources = activeSources.concat([{ field: PROJECT_PAYLOAD_FIELDS.ENVIRONMENT_STATUTORY_FUNDING, label: t(p + '.environment_statutory_funding'), additionalGia: true }]) %}
  {% endif %}
  {% if projectData[PROJECT_PAYLOAD_FIELDS.FREQUENTLY_FLOODED_COMMUNITIES] %}
    {% set activeSources = activeSources.concat([{ field: PROJECT_PAYLOAD_FIELDS.FREQUENTLY_FLOODED_COMMUNITIES, label: t(p + '.frequently_flooded_communities'), additionalGia: true }]) %}
  {% endif %}
  {% if projectData[PROJECT_PAYLOAD_FIELDS.OTHER_ADDITIONAL_GRANT_IN_AID] %}
    {% set activeSources = activeSources.concat([{ field: PROJECT_PAYLOAD_FIELDS.OTHER_ADDITIONAL_GRANT_IN_AID, label: t(p + '.other_additional_grant_in_aid'), additionalGia: true }]) %}
  {% endif %}
  {% if projectData[PROJECT_PAYLOAD_FIELDS.OTHER_GOVERNMENT_DEPARTMENT] %}
    {% set activeSources = activeSources.concat([{ field: PROJECT_PAYLOAD_FIELDS.OTHER_GOVERNMENT_DEPARTMENT, label: t(p + '.other_government_department'), additionalGia: true }]) %}
  {% endif %}
  {% if projectData[PROJECT_PAYLOAD_FIELDS.RECOVERY] %}
    {% set activeSources = activeSources.concat([{ field: PROJECT_PAYLOAD_FIELDS.RECOVERY, label: t(p + '.recovery'), additionalGia: true }]) %}
  {% endif %}
  {% if projectData[PROJECT_PAYLOAD_FIELDS.SUMMER_ECONOMIC_FUND] %}
    {% set activeSources = activeSources.concat([{ field: PROJECT_PAYLOAD_FIELDS.SUMMER_ECONOMIC_FUND, label: t(p + '.summer_economic_fund'), additionalGia: true }]) %}
  {% endif %}
  {% if projectData[PROJECT_PAYLOAD_FIELDS.PUBLIC_CONTRIBUTIONS] %}
    {% set activeSources = activeSources.concat([{ field: PROJECT_PAYLOAD_FIELDS.PUBLIC_CONTRIBUTIONS, label: t(p + '.public_sector_contributors'), contributorArrayField: 'publicContributors' }]) %}
  {% endif %}
  {% if projectData[PROJECT_PAYLOAD_FIELDS.PRIVATE_CONTRIBUTIONS] %}
    {% set activeSources = activeSources.concat([{ field: PROJECT_PAYLOAD_FIELDS.PRIVATE_CONTRIBUTIONS, label: t(p + '.private_sector_contributors'), contributorArrayField: 'privateContributors' }]) %}
  {% endif %}
  {% if projectData[PROJECT_PAYLOAD_FIELDS.OTHER_EA_CONTRIBUTIONS] %}
    {% set activeSources = activeSources.concat([{ field: PROJECT_PAYLOAD_FIELDS.OTHER_EA_CONTRIBUTIONS, label: t(p + '.other_ea_contributors'), contributorArrayField: 'otherEaContributors' }]) %}
  {% endif %}
  {% if projectData[PROJECT_PAYLOAD_FIELDS.NOT_YET_IDENTIFIED] %}
    {% set activeSources = activeSources.concat([{ field: PROJECT_PAYLOAD_FIELDS.NOT_YET_IDENTIFIED, label: t(p + '.not_yet_identified') }]) %}
  {% endif %}

<div class="govuk-summary-card">
  <div class="govuk-summary-card__title-wrapper">
    <h2 class="govuk-summary-card__title">{{ t(p + '.title') }}</h2>
    {% if not isReadOnly %}
      <ul class="govuk-summary-card__actions">
        <li class="govuk-summary-card__action">
          <a class="govuk-link" href="/project/{{ slug }}/{{ PROJECT_STEPS.FUNDING_SOURCES }}">
            {% if hasFundingSources %}{{ t('common.change') }}{% else %}{{ t('common.add') }}{% endif %}
            <span class="govuk-visually-hidden"> {{ t(p + '.title') | lower }}</span>
          </a>
        </li>
      </ul>
    {% endif %}
  </div>
  <div class="govuk-summary-card__content">
    {% if hasFundingSources and hasSpend and activeSources | length > 0 %}

      {# Summary totals table – additional GIA sources aggregated into one row #}
      {# Build summary sources: non-GIA sources + single aggregated GIA row #}
      {# additionalGiaTotal is pre-computed in JS (as a string) to avoid     #}
      {# Nunjucks string-concatenation when sourceTotals values are strings.  #}
      {% set summarySources = [] %}
      {% set additionalGiaTotal = projectData.fundingSourceTotals.additionalGiaTotal or 0 %}
      {% set hasAdditionalGia = false %}

      {% for source in activeSources %}
        {% if source.additionalGia %}
          {% set hasAdditionalGia = true %}
        {% else %}
          {% set summarySources = summarySources.concat([source]) %}
        {% endif %}
      {% endfor %}

      <table class="govuk-table">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">{{ t(p + '.funding_source') }}</th>
            <th scope="col" class="govuk-table__header govuk-table__header--numeric">{{ t(p + '.total_estimated_spend') }}</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          {% for source in summarySources %}
            {% if not source.contributorArrayField %}
              {% set sourceTotal = projectData.fundingSourceTotals.sourceTotals[source.field] or 0 %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">{{ source.label }}</td>
                <td class="govuk-table__cell govuk-table__cell--numeric">
                  {% if sourceTotal > 0 %}£{{ formatNumberWithCommas(sourceTotal) }}{% else %}0{% endif %}
                </td>
              </tr>
            {% endif %}
          {% endfor %}

          {# Single aggregated Additional FCRM Grant-in-Aid row #}
          {% if hasAdditionalGia %}
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">{{ t(p + '.additional_gia') }}</td>
              <td class="govuk-table__cell govuk-table__cell--numeric">
                {% if additionalGiaTotal > 0 %}£{{ formatNumberWithCommas(additionalGiaTotal) }}{% else %}0{% endif %}
              </td>
            </tr>
          {% endif %}

          {# Contributor sources #}
          {% for source in summarySources %}
            {% if source.contributorArrayField %}
              {% set sourceTotal = projectData.fundingSourceTotals.sourceTotals[source.field] or 0 %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">{{ source.label }}</td>
                <td class="govuk-table__cell govuk-table__cell--numeric">
                  {% if sourceTotal > 0 %}£{{ formatNumberWithCommas(sourceTotal) }}{% else %}0{% endif %}
                </td>
              </tr>
            {% endif %}
          {% endfor %}
        </tbody>
        <tfoot class="govuk-table__foot">
          <tr class="govuk-table__row">
            <th scope="row" class="govuk-table__header">{{ t(p + '.total_with_pound_symbol') }}</th>
            <td class="govuk-table__cell govuk-table__cell--numeric">
              <strong>{% if projectData.fundingSourceTotals.grandTotal > 0 %}£{{ formatNumberWithCommas(projectData.fundingSourceTotals.grandTotal) }}{% else %}0{% endif %}</strong>
            </td>
          </tr>
        </tfoot>
      </table>

      {# Expandable detail: year-by-year breakdown matching estimated-spend layout #}
      <details class="govuk-details govuk-!-margin-top-4" data-module="govuk-details">
        <summary class="govuk-details__summary">
          <span class="govuk-details__summary-text">{{ t(p + '.view_funding_sources_and_spending_detail') }}</span>
        </summary>
        <div class="govuk-details__text">
          <div class="pafs-table-scroll">
            <table class="govuk-table funding_sources_and_spending_detail_table">
              <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                  <th scope="col" class="govuk-table__header app-funding-table__source-header">{{ t(p + '.funding_source') }}</th>
                  {% for row in fundingValues %}
                    <th scope="col" class="govuk-table__header govuk-table__header--numeric">
                      {{ row[PROJECT_PAYLOAD_FIELDS.FINANCIAL_YEAR] % 100 }}/{{ (row[PROJECT_PAYLOAD_FIELDS.FINANCIAL_YEAR] + 1) % 100 }}
                    </th>
                  {% endfor %}
                  <th scope="col" class="govuk-table__header govuk-table__header--numeric">{{ t(p + '.total_with_pound_symbol') }}</th>
                </tr>
              </thead>
              <tbody class="govuk-table__body">
                {% for source in activeSources %}
                  {% if source.contributorArrayField %}

                    {# ── Group heading row ── #}
                    <tr class="govuk-table__row">
                      <th scope="row" class="govuk-table__header detail-section-header" colspan="{{ fundingValues | length + 2 }}">
                        <strong>{{ source.label }}</strong>
                      </th>
                    </tr>

                    {# Collect unique contributor names for this group #}
                    {% set contribNames = [] %}
                    {% for row in fundingValues %}
                      {% for contrib in (row[source.contributorArrayField] or []) %}
                        {% if contrib.name and contrib.name not in contribNames %}
                          {% set contribNames = contribNames.concat([contrib.name]) %}
                        {% endif %}
                      {% endfor %}
                    {% endfor %}

                    {# ── Contributor name rows ── #}
                    {% for name in contribNames %}
                      <tr class="govuk-table__row">
                        <td class="govuk-table__cell detail-contributor-name">{{ name }}</td>
                        {% for row in fundingValues %}
                          {% set val = null %}
                          {% for contrib in (row[source.contributorArrayField] or []) %}
                            {% if contrib.name == name %}
                              {% set val = contrib.amount %}
                            {% endif %}
                          {% endfor %}
                          <td class="govuk-table__cell govuk-table__cell--numeric">{{ formatNumberWithCommas(val) if val > 0 else '0' }}</td>
                        {% endfor %}
                        {% set rowTotal = projectData.fundingSourceTotals.contributorRowTotals[source.contributorArrayField][name] or '0' %}
                        <td class="govuk-table__cell govuk-table__cell--numeric">{{ formatNumberWithCommas(rowTotal) if rowTotal > 0 else '0' }}</td>
                      </tr>
                    {% endfor %}

                  {% else %}

                    {# ── Regular source row ── #}
                    <tr class="govuk-table__row">
                      <th scope="row" class="govuk-table__header">{{ source.label }}</th>
                      {% for row in fundingValues %}
                        {% set val = row[source.field] %}
                        <td class="govuk-table__cell govuk-table__cell--numeric">{{ formatNumberWithCommas(val) if val > 0 else '0' }}</td>
                      {% endfor %}
                      {% set rowTotal = projectData.fundingSourceTotals.sourceTotals[source.field] or 0 %}
                      <td class="govuk-table__cell govuk-table__cell--numeric">{{ formatNumberWithCommas(rowTotal) if rowTotal > 0 else '0' }}</td>
                    </tr>

                  {% endif %}
                {% endfor %}
              </tbody>
              <tfoot class="govuk-table__foot">
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell"><strong>{{ t(p + '.total_with_pound_symbol') }}</strong></td>
                  {% for row in fundingValues %}
                    {% set colTotal = projectData.fundingSourceTotals.yearTotals[loop.index0] or 0 %}
                    <td class="govuk-table__cell govuk-table__cell--numeric">{{ formatNumberWithCommas(colTotal) if colTotal > 0 else '0' }}</td>
                  {% endfor %}
                  {% set gt = projectData.fundingSourceTotals.grandTotal or 0 %}
                  <td class="govuk-table__cell govuk-table__cell--numeric">{{ formatNumberWithCommas(gt) if gt > 0 else '0' }}</td>
                </tr>
              </tfoot>
            </table>
          </div>
        </div>
      </details>

    {% elif hasFundingSources %}
      <p class="govuk-body">{{ t(p + '.not_added') }}</p>
    {% else %}
      <p class="govuk-body">{{ t(p + '.not_added') }}</p>
    {% endif %}
  </div>
</div>

{% endmacro %}
