{% macro goalsApproachSummaryCard(projectData, PROJECT_PAYLOAD_FIELDS, PROJECT_STEPS, t, isReadOnly) %}
  {% set hasApproach = projectData[PROJECT_PAYLOAD_FIELDS.APPROACH] %}
  <div class="govuk-summary-card">
    <div class="govuk-summary-card__title-wrapper">
      <h2 class="govuk-summary-card__title">{{ t('projects.overview.goals_approach_summary_card.title') }}</h2>
      {% if not isReadOnly %}
        <ul class="govuk-summary-card__actions">
          <li class="govuk-summary-card__action">
            <a class="govuk-link" href="/project/{{ projectData[PROJECT_PAYLOAD_FIELDS.SLUG] }}/{{ PROJECT_STEPS.PROJECT_GOALS }}">
              {% if hasApproach %}{{ t('common.change') }}
              {% else %}{{ t('common.add') }}
              {% endif %}
              <span class="govuk-visually-hidden">
                {{ t('projects.overview.goals_approach_summary_card.title') | lower }}</span>
            </a>
          </li>
        </ul>
      {% endif %}
    </div>
    <div class="govuk-summary-card__content">
      {% if hasApproach %}
        <p class="govuk-body">{{ projectData[PROJECT_PAYLOAD_FIELDS.APPROACH] }}</p>
      {% else %}
        <p class="govuk-body">{{ t('projects.overview.goals_approach_summary_card.not_added') }}</p>
      {% endif %}
    </div>
  </div>
{% endmacro %}
