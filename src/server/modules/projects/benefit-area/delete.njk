{% extends "layouts/page.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-xl">{{ t(localKeyPrefix + '.heading') }}</h1>

      <p class="govuk-body">
        {% if formData[PROJECT_PAYLOAD_FIELDS.BENEFIT_AREA_FILE_DOWNLOAD_URL] %}
          <a class="govuk-link" href="{{ formData[PROJECT_PAYLOAD_FIELDS.BENEFIT_AREA_FILE_DOWNLOAD_URL] }}" download>
            {{ formData[PROJECT_PAYLOAD_FIELDS.BENEFIT_AREA_FILE_NAME] }}
          </a>
        {% else %}
          {{ formData[PROJECT_PAYLOAD_FIELDS.BENEFIT_AREA_FILE_NAME] }}
        {% endif %}
      </p>

      <p class="govuk-body">{{ t(localKeyPrefix + '.warning') }}</p>

      <form method="post" action="">
        <input type="hidden" name="crumb" value="{{ crumb }}">
        <input type="hidden" name="confirm" value="yes">
        <div class="govuk-button-group">
          {{ govukButton({
            text: t(localKeyPrefix + '.delete_button'),
            classes: "govuk-button--warning"
          }) }}
          <a class="govuk-link" href="{{ backLinkURL }}">{{ t('common.cancel_link') }}</a>
        </div>
      </form>
    </div>
  </div>
{% endblock %}