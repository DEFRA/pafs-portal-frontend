{% extends "layouts/projects.njk" %}
{% from "button.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block titleText %}{{ t(localKeyPrefix + '.title') }}{% endblock %}

{% block body %}
  {% set beforeError = fieldErrors[beforeFieldName] %}
  {% set afterError = fieldErrors[afterFieldName] %}
  {% set beforeErrorText = t(localKeyPrefix + '.validation.' + beforeError) if beforeError else undefined %}
  {% set afterErrorText = t(localKeyPrefix + '.validation.' + afterError) if afterError else undefined %}
  {% set showBothErrors = beforeError and afterError and beforeError != afterError %}

  {% if beforeError or afterError %}
    {{ govukErrorSummary({
      titleText: t('common.error_summary_title'),
      errorList: showBothErrors and [
        {
          text: beforeErrorText,
          href: '#' + beforeFieldName
        },
        {
          text: afterErrorText,
          href: '#' + afterFieldName
        }
      ] or [
        {
          text: beforeErrorText or afterErrorText,
          href: '#' + (beforeFieldName if beforeError else afterFieldName)
        }
      ]
    }) }}
  {% endif %}

  <form method="post" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}">
    <div class="govuk-form-group {% if fieldErrors[beforeFieldName] or fieldErrors[afterFieldName] %}govuk-form-group--error{% endif %}">
      <h1 class="govuk-heading-l">{{ t(localKeyPrefix + '.title') }}</h1>

      {{ govukInput({
        label: {
          text: t(localKeyPrefix + '.before.label'),
          classes: "govuk-label--m",
          isPageHeading: false
        },
        id: beforeFieldName,
        name: beforeFieldName,
        value: formData[beforeFieldName] if formData[beforeFieldName] else '',
        suffix: {
          text: "hectares"
        },
        classes: "govuk-input--width-10",
        errorMessage: {
          text: beforeErrorText
        } if beforeError else undefined
      }) }}

      {{ govukInput({
        label: {
          text: t(localKeyPrefix + '.after.label'),
          classes: "govuk-label--m",
          isPageHeading: false
        },
        id: afterFieldName,
        name: afterFieldName,
        value: formData[afterFieldName] if formData[afterFieldName] else '',
        suffix: {
          text: "hectares"
        },
        classes: "govuk-input--width-10",
        errorMessage: {
          text: afterErrorText
        } if afterError else undefined
      }) }}
    </div>

    <div class="govuk-button-group">
      {{ govukButton({
        text: t('common.buttons.save_and_continue')
      }) }}
    </div>
  </form>
{% endblock %}
