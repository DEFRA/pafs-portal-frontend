{% extends 'layouts/projects.njk' %}

{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block body %}
  {% set hasProjectReadinessError = fieldErrors and fieldErrors[PROJECT_PAYLOAD_FIELDS.NFM_PROJECT_READINESS] %}

  {% if hasProjectReadinessError %}
    {{ govukErrorSummary({
      titleText: t('common.error_summary_title'),
      errorList: [
        {
          text: t(localKeyPrefix + '.error'),
          href: '#nfmProjectReadiness'
        }
      ]
    }) }}
  {% endif %}

  <form method="POST" novalidate>
    <input type="hidden" name="crumb" value="{{ crumb }}">

    {{ govukRadios({
      idPrefix: PROJECT_PAYLOAD_FIELDS.NFM_PROJECT_READINESS,
      name: PROJECT_PAYLOAD_FIELDS.NFM_PROJECT_READINESS,
      value: formData[PROJECT_PAYLOAD_FIELDS.NFM_PROJECT_READINESS],
      fieldset: {
        legend: {
          text: t(localKeyPrefix + '.heading'),
          classes: "govuk-fieldset__legend--xl",
          isPageHeading: true
        }
      },
      items: nfmProjectReadinessOptions,
      errorMessage: hasProjectReadinessError and {
        text: t(localKeyPrefix + '.error')
      }
    }) }}

    {{ govukButton({
      text: t('common.buttons.save_and_continue')
    }) }}
  </form>
{% endblock %}
