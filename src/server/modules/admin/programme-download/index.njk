{% extends 'layouts/page.njk' %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}

{% set status = downloadStatus.status if downloadStatus else 'empty' %}
{% set projectCounts = downloadStatus.projectCounts if downloadStatus else null %}

{% set progressPct = 0 %}
{% if downloadStatus and downloadStatus.progressTotal > 0 %}
  {% set progressPct = ((downloadStatus.progressCurrent / downloadStatus.progressTotal) * 100) | round %}
{% endif %}

{% block content %}

  {% if flash %}
    {{ govukNotificationBanner({
      type: flash.type,
      html: '<p class="govuk-body">' + flash.text + '</p>'
    }) }}
  {% endif %}

  <h1 class="govuk-heading-xl">{{ heading }}</h1>

  {# ── Live project counts ────────────────────────────────────────────────── #}
  {% if projectCounts %}
    <div class="govuk-grid-row govuk-!-margin-bottom-6">
      <div class="govuk-grid-column-two-thirds">
        <h2 class="govuk-heading-m">{{ t('download.admin.counts.heading') }}</h2>
        {{ govukSummaryList({
          rows: [
            { key: { text: t('download.admin.counts.total') },     value: { text: projectCounts.total } },
            { key: { text: t('download.admin.counts.submitted') }, value: { text: projectCounts.submitted } },
            { key: { text: t('download.admin.counts.draft') },     value: { text: projectCounts.draft } },
            { key: { text: t('download.admin.counts.completed') }, value: { text: projectCounts.completed } },
            { key: { text: t('download.admin.counts.archived') },  value: { text: projectCounts.archived } }
          ],
          classes: "govuk-summary-list--no-border"
        }) }}
        <p class="govuk-body govuk-hint">{{ t('download.admin.counts.note') }}</p>
      </div>
    </div>
  {% endif %}

  {# ── Status panel ───────────────────────────────────────────────────────── #}
  {#
    data-module, data-download-status, and data-poll-url are consumed by
    programme-download.js for progressive enhancement.
    Without JS: the generating state auto-refreshes every 10s via <noscript> meta.
  #}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds"
         data-module="programme-download"
         data-download-status="{{ status }}"
         data-poll-url="/admin/downloads/poll"
         data-is-admin="true">

      {# EMPTY / FAILED ──────────────────────────────────────────────────── #}
      {% if status === 'empty' or status === 'failed' %}

        {% if status === 'failed' %}
          {{ govukNotificationBanner({
            type: 'important',
            titleText: t('download.admin.failed.title'),
            html: '<p class="govuk-body">' + t('download.admin.failed.body') + '</p>'
          }) }}
        {% endif %}

        {{ govukInsetText({
          text: t('download.admin.empty.description')
        }) }}

        <form method="post" action="/admin/downloads/generate">
          <input type="hidden" name="_csrf" value="{{ crumb }}">
          {{ govukButton({
            text: t('download.admin.button.generate'),
            preventDoubleClick: true
          }) }}
        </form>

      {# GENERATING ──────────────────────────────────────────────────────── #}
      {% elif status === 'generating' %}

        <div class="govuk-inset-text" id="js-generating-panel">
          <h2 class="govuk-heading-s">{{ t('download.admin.generating.heading') }}</h2>
          <p class="govuk-body" id="js-progress-message">
            {{ downloadStatus.progressMessage or t('download.admin.generating.default_message') }}
          </p>

          {# Progress bar ──────────────────────────────────────────────── #}
          {% if downloadStatus.progressTotal > 0 %}
            <div class="govuk-!-margin-bottom-2">
              <div role="progressbar"
                   aria-label="{{ t('download.admin.generating.progress_label') }}"
                   aria-valuenow="{{ progressPct }}"
                   aria-valuemin="0"
                   aria-valuemax="100"
                   style="background:#f3f2f1; border-radius:4px; height:20px; overflow:hidden;">
                <div id="js-progress-bar"
                     style="background:#00703c; height:100%; width:{{ progressPct }}%; transition:width 0.5s ease;"></div>
              </div>
            </div>
            <p class="govuk-body govuk-hint" id="js-progress-count">
              {{ downloadStatus.progressCurrent }} {{ t('download.admin.generating.of') }} {{ downloadStatus.progressTotal }}
              ({{ progressPct }}%)
            </p>
          {% endif %}

          <p class="govuk-body">{{ t('download.admin.generating.email_notice') }}</p>
        </div>

        {% if downloadStatus.requestedOn %}
          <p class="govuk-body govuk-hint">
            {{ t('download.admin.generating.requested_on') }}
            {{ downloadStatus.requestedOn | formatDate('d MMMM yyyy') }}
          </p>
        {% endif %}

        <form method="post" action="/admin/downloads/generate">
          <input type="hidden" name="_csrf" value="{{ crumb }}">
          {{ govukButton({
            text: t('download.admin.button.generate_again'),
            classes: "govuk-button--secondary govuk-!-margin-top-2",
            preventDoubleClick: true
          }) }}
        </form>

        {# No-JS fallback: auto-refresh every 10 seconds #}
        <noscript><meta http-equiv="refresh" content="10"></noscript>

      {# READY ───────────────────────────────────────────────────────────── #}
      {% elif status === 'ready' %}

        <h2 class="govuk-heading-m">{{ t('download.admin.ready.heading') }}</h2>

        {% if downloadStatus.requestedOn %}
          <p class="govuk-body govuk-hint govuk-!-margin-bottom-1">
            {{ t('download.admin.ready.generated_on') }}
            {{ downloadStatus.requestedOn | formatDate('d MMMM yyyy') }}
          </p>
        {% endif %}
        {% if downloadStatus.numberOfProposals is not null %}
          <p class="govuk-body govuk-hint govuk-!-margin-bottom-6">
            {{ t('download.admin.ready.included_proposals') }}
            <strong>{{ downloadStatus.numberOfProposals }}</strong>
            {{ t('download.admin.ready.proposals') }}
          </p>
        {% endif %}

        {# FCERM1 download — all non-archived projects #}
        {% if downloadStatus.hasFcerm1 %}
          <section class="gem-c-attachment govuk-!-margin-bottom-6">
            <div class="gem-c-attachment__thumbnail">
              <a href="/admin/downloads/file" class="govuk-link" tabindex="-1" aria-hidden="true">
                <svg class="gem-c-attachment__thumbnail-image gem-c-attachment__thumbnail-image--spreadsheet"
                     version="1.1" viewBox="0 0 99 140" width="99" height="140" aria-hidden="true">
                  <path d="M12 12h75v27H12zm0 47h18.75v63H12zm55 2v59H51V61h16m2-2H49v63h20V59z" stroke-width="0"/>
                  <path d="M49 61.05V120H32.8V61.05H49m2-2H30.75v63H51V59zm34 2V120H69.05V61.05H85m2-2H67v63h20V59z" stroke-width="0"/>
                  <path d="M30 68.5h56.5M30 77.34h56.5M30 112.7h56.5M30 95.02h56.5M30 86.18h56.5M30 103.86h56.5" fill="none" stroke-miterlimit="10" stroke-width="2"/>
                </svg>
              </a>
            </div>
            <div class="gem-c-attachment__details">
              <h3 class="gem-c-attachment__title">
                <a href="/admin/downloads/file" class="govuk-link gem-c-attachment__link">
                  {{ t('download.admin.ready.fcerm1_label') }}
                </a>
              </h3>
              <p class="gem-c-attachment__metadata">
                <span class="gem-c-attachment__attribute">MS Excel Spreadsheet (.xlsx)</span>
              </p>
              <p class="gem-c-attachment__metadata">
                <span class="gem-c-attachment__attribute">{{ t('download.admin.ready.fcerm1_hint') }}</span>
              </p>
            </div>
          </section>
        {% endif %}

        <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">

        <form method="post" action="/admin/downloads/generate">
          <input type="hidden" name="_csrf" value="{{ crumb }}">
          {{ govukButton({
            text: t('download.admin.button.regenerate'),
            classes: "govuk-button--secondary govuk-!-margin-top-4",
            preventDoubleClick: true
          }) }}
        </form>

      {% endif %}

    </div>
  </div>

{% endblock %}
