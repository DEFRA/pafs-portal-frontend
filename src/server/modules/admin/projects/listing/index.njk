{% extends "layouts/page.njk" %}

{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    <h1 class="govuk-heading-xl">{{ t('projects.manage_projects.heading') }}</h1>

    {# Filter form #}
    <form action="{{ baseUrl }}" method="get" class="govuk-!-margin-bottom-6" role="search" aria-label="{{ t('projects.manage_projects.filters.aria_label') }}" data-testid="projects-filter-form">
      {{ govukInput({
        label: {
          text: t('projects.manage_projects.filters.search_label'),
          classes: "govuk-label"
        },
        id: "search",
        name: "search",
        value: filters.search,
        classes: "govuk-!-width-two-thirds",
        attributes: {
          "aria-describedby": "search-hint"
        }
      }) }}
      <span id="search-hint" class="govuk-visually-hidden">{{ t('projects.manage_projects.filters.search_hint') }}</span>

      <div class="govuk-form-group">
        <label class="govuk-label" for="area-filter">
          {{ t('projects.manage_projects.filters.area_label') }}
        </label>
        <select class="govuk-select govuk-!-width-two-thirds" id="area-filter" name="areaId">
          {% for area in areas %}
            <option value="{{ area.value }}"{% if area.value == filters.areaId %} selected{% endif %}>{{ area.text }}</option>
          {% endfor %}
        </select>
      </div>

      <div class="govuk-button-group">
        {{ govukButton({
          text: t('projects.manage_projects.filters.filter_button'),
          type: "submit"
        }) }}
        <a href="{{ baseUrl }}" class="govuk-link" data-testid="clear-filters">
          {{ t('projects.manage_projects.filters.clear_filters') }}
        </a>
      </div>
    </form>

    <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible" aria-hidden="true">

    {# Projects table #}
    {% if error %}
      <p class="govuk-body govuk-error-message" data-testid="projects-error">{{ error }}</p>
    {% elif projects | length > 0 %}
      <table class="govuk-table app-table--responsive app-users-table" data-testid="projects-table">
        <caption class="govuk-visually-hidden">{{ t('projects.manage_projects.table.caption') }}</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">{{ t('projects.manage_projects.table.project_number') }}</th>
            <th scope="col" class="govuk-table__header govuk-!-width-one-quarter">{{ t('projects.manage_projects.table.project_name') }}</th>
            <th scope="col" class="govuk-table__header govuk-!-width-one-tenth">{{ t('projects.manage_projects.table.status.label') }}</th>
            <th scope="col" class="govuk-table__header govuk-!-width-half-quarter">{{ t('projects.manage_projects.table.last_updated') }}</th>
            <th scope="col" class="govuk-table__header govuk-!-width-one-quarter">{{ t('projects.manage_projects.table.assigned_rma') }}</th>
            <th scope="col" class="govuk-table__header govuk-!-width-one-tenth">{{ t('projects.manage_projects.table.action') }}</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          {% for project in projects %}
            <tr class="govuk-table__row" data-testid="projects-table-row">
              <td class="govuk-table__cell" data-label="{{ t('projects.manage_projects.table.project_number') }}" data-testid="project-number"><strong>{{ project.referenceNumber }}</strong></td>
              <td class="govuk-table__cell" data-label="{{ t('projects.manage_projects.table.project_name') }}" data-testid="project-name">{{ project.name }}</td>
              <td class="govuk-table__cell" data-label="{{ t('projects.manage_projects.table.status.label') }}" data-testid="status">
                {% if project.status == 'draft' %}
                  {{ t('projects.manage_projects.table.status.draft') }}
                {% elif project.status == 'submitted' %}
                  {{ t('projects.manage_projects.table.status.submitted') }}
                {% elif project.status == 'archived' %}
                  {{ t('projects.manage_projects.table.status.archived') }}
                {% endif %}
              </td>
              <td class="govuk-table__cell govuk-!-white-space-nowrap" data-label="{{ t('projects.manage_projects.table.last_updated') }}" data-testid="last-updated">
                {{ project.updatedAt | formatDate('d MMM yyyy') }}&nbsp;
                <span class="govuk-hint govuk-!-font-size-16">{{ project.updatedAt | formatDate('HH:mm') }}</span>
              </td>
              <td class="govuk-table__cell" data-label="{{ t('projects.manage_projects.table.assigned_rma') }}" data-testid="assigned-rma">{{ project.rmaName | default('-') }}</td>
              <td class="govuk-table__cell" data-label="">
                <a href="/admin/projects/{{ project.referenceNumberFormatted }}" class="govuk-link" data-testid="project-edit-link">
                  {{ t('projects.manage_projects.table.edit') }}
                  <span class="govuk-visually-hidden">{{ project.referenceNumber }}</span>
                </a>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p class="govuk-body" data-testid="projects-empty">{{ t('projects.manage_projects.empty') }}</p>
    {% endif %}

    {# Pagination row with summary and navigation #}
    {% if pagination.summary or pagination.items or pagination.previous or pagination.next %}
    <div class="app-pagination-row govuk-!-margin-top-6">
      {# Pagination summary #}
      {% if pagination.summary %}
      <p class="govuk-body app-pagination-row__summary" data-testid="pagination-summary">
        {{ t('projects.manage_projects.pagination.showing') }}
        <strong>{{ pagination.summary.startItem }}</strong>
        {{ t('projects.manage_projects.pagination.to') }}
        <strong>{{ pagination.summary.endItem }}</strong>
        {{ t('projects.manage_projects.pagination.of') }}
        <strong>{{ pagination.summary.totalItems }}</strong>
        {{ t('projects.manage_projects.pagination.projects') }}
      </p>
      {% endif %}

      {# GOV.UK Pagination #}
      {% if pagination.items or pagination.previous or pagination.next %}
      <div class="app-pagination-row__nav">
        {{ govukPagination({
          items: pagination.items,
          previous: pagination.previous,
          next: pagination.next,
          landmarkLabel: t('projects.manage_projects.pagination.aria_label')
        }) }}
      </div>
      {% endif %}
    </div>
    {% endif %}

  </div>
</div>
{% endblock %}
